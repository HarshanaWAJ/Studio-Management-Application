# ─────────── Database ───────────
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrongPassword!
DB_NAME=StudioDB

# ─────────── JWT ───────────────
JWT_SECRET=your-very-strong-secret-key-change-this
JWT_REFRESH_SECRET=your-very-strong-refresh-secret-change-this
JWT_EXPIRES_IN=15m
# Deliberately separate from JWT_SECRET so a Super Admin (platform) token can
# never be accepted by any studio data route, and vice versa.
PLATFORM_JWT_SECRET=your-very-strong-platform-admin-secret-change-this
JWT_REFRESH_EXPIRES_IN=7d

# ─────────── Server ────────────
PORT=8088
FRONTEND_URL=http://localhost:3000

# ─────────── Email (Gmail SMTP — free) ───────────
# 1. Enable 2-Step Verification on the Gmail account you want to send from
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character app password below (NOT your normal Gmail password)
EMAIL_USER=your-studio@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_FROM_NAME=JH Studio

# If "true", users must verify their email (via OTP) before they can log in.
REQUIRE_EMAIL_VERIFICATION=true

# ─────────── AI Assist ───────────
# AI Assist (booking parsing, package recommendations, website copy) runs
# entirely in-process using a built-in local NLP engine (compromise) — no
# API key or external service is required.

# ─────────── SaaS Platform / Super Admin ───────────
# A single Platform (Super Admin) account is auto-seeded on first server
# start using these credentials if one doesn't already exist.
PLATFORM_ADMIN_EMAIL=superadmin@studiosaas.com
PLATFORM_ADMIN_PASSWORD=ChangeMe@12345
PLATFORM_ADMIN_NAME=Platform Owner

# Default overage price ($) per extra user/month beyond a plan's included
# user count, used when a plan doesn't set its own override.
DEFAULT_OVERAGE_PRICE_PER_USER=5
